  {
    q:"tRNA의 '동요 현상(Wobble)'의 정의와 그것이 필요한 이유(코돈과 tRNA 수의 관계)를 서술하시오.",
    a:"• 정의: 코돈의 3번째 염기(5'기준)와 안티코돈의 1번째 염기 간의 염기쌍 엄격성이 낮아, 하나의 tRNA가 여러 코돈을 인식할 수 있는 현상\n• 안티코돈 G → 코돈 3번째 C 또는 U 인식 / 안티코돈 U → 코돈 3번째 A 또는 G 인식\n• 필요한 이유: 61종 코돈에 대해 tRNA는 45종뿐으로, 일대일대응 불가 → 동요 현상으로 하나의 tRNA가 동일 아미노산을 지정하는 여러 코돈 인식\n• 전제조건: 두 코돈이 같은 아미노산을 지정할 때만 적용"
  },
  {
    q:"신호 인식 입자(SRP)를 이용한 폴리펩타이드의 소포체 이동 과정을 순서대로 설명하시오.",
    a:"① 리보솜에서 신호펩타이드(폴리펩타이드 앞부분) 합성 시작\n② 신호인식입자(SRP, 단백질-RNA 복합체)가 신호펩타이드에 결합 → 폴리펩타이드 합성 일시 중단\n③ SRP가 소포체막의 수용체 단백질에 부착\n④ SRP 분리 → 폴리펩타이드 합성 재개, 소포체 막 통과\n⑤ 신호절단효소가 신호펩타이드를 제거 → 폴리펩타이드 완성 후 입체구조로 접힘"
  },
];

/* ===== 상태 변수 ===== */
let order = 'seq', questions = [], idx = 0;
let correct = 0, wrong = 0, skipped = 0;
let wrongList = [], isRetry = false, answered = false;

/* ===== 유틸 ===== */
function shuffle(arr) {
  let a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function normalize(s) { return s.trim().replace(/\s+/g, ' ').toLowerCase(); }

/* ===== 모드 전환 ===== */
function switchMode(m) {
  document.querySelectorAll('.tab').forEach((t, i) => {
    t.classList.toggle('active', (m === 'blank' && i === 0) || (m === 'essay' && i === 1));
  });
  document.getElementById('blank-mode').style.display = m === 'blank' ? '' : 'none';
  document.getElementById('essay-mode').style.display  = m === 'essay'  ? '' : 'none';
  if (m === 'essay') renderEssay();
}

/* ===== 순서 설정 ===== */
function setOrder(o) {
  order = o;
  document.getElementById('btn-seq').classList.toggle('active', o === 'seq');
  document.getElementById('btn-shuf').classList.toggle('active', o === 'shuf');
  startQuiz();
}

/* ===== 퀴즈 시작 ===== */
function startQuiz() {
  isRetry = false; wrongList = [];
  questions = order === 'shuf' ? shuffle(RAW) : [...RAW];
  idx = 0; correct = 0; wrong = 0; skipped = 0; answered = false;
  document.getElementById('retry-section').style.display  = 'none';
  document.getElementById('result-section').style.display = 'none';
  document.getElementById('q-card').style.display = '';
  renderQ();
}

function startRetry() {
  isRetry = true;
  questions = [...wrongList]; wrongList = [];
  idx = 0; correct = 0; wrong = 0; skipped = 0; answered = false;
  document.getElementById('retry-section').style.display  = 'none';
  document.getElementById('result-section').style.display = 'none';
  document.getElementById('q-card').style.display = '';
  renderQ();
}

/* ===== 문제 렌더 ===== */
function renderQ() {
  answered = false;
  const q = questions[idx];
  const total = questions.length;
  document.getElementById('q-idx').textContent = `문제 ${idx + 1} / ${total}`;
  document.getElementById('q-score-mini').textContent = `맞힌 수: ${correct}`;
  document.getElementById('prog').style.width = `${(idx / total) * 100}%`;

  const display = q.s.replace(/\[([^\]]+)\]/g, '<span class="blank">?</span>');
  document.getElementById('q-text').innerHTML = display;
  document.getElementById('q-hint').textContent = `힌트: ${q.h}`;
  document.getElementById('ans-input').value = '';
  document.getElementById('ans-input').disabled = false;
  document.getElementById('feedback').style.display = 'none';
  document.getElementById('nav-row').style.display = 'none';
  setTimeout(() => document.getElementById('ans-input').focus(), 50);
}

/* ===== 정답 확인 ===== */
function checkAns() {
  if (answered) return;
  const q = questions[idx];
  const input = document.getElementById('ans-input').value;
  const fb = document.getElementById('feedback');

  let userN = normalize(input);
  let ansN  = normalize(q.a);
  let isCorrect = userN === ansN;

  // 슬래시 구분 허용
  if (!isCorrect && ansN.split('/').map(s => s.trim()).includes(userN)) isCorrect = true;
  // "3/1" 형식 허용
  if (!isCorrect && userN.replace(/\s/g,'') === ansN.replace(/\s/g,'')) isCorrect = true;
  // SRP 약어 허용
  if (!isCorrect && (userN === 'srp' && ansN.includes('srp'))) isCorrect = true;

  answered = true;
  document.getElementById('ans-input').disabled = true;

  const fullSentence = q.s.replace(/\[([^\]]+)\]/g, '<strong>$1</strong>');

  if (isCorrect) {
    correct++;
    fb.className = 'feedback correct';
    fb.innerHTML = `정답입니다! ✓<br><span style="font-size:13px;margin-top:4px;display:block">${fullSentence}</span>`;
  } else {
    wrong++;
    wrongList.push(q);
    fb.className = 'feedback wrong';
    fb.innerHTML = `오답입니다. 정답: <strong>${q.a}</strong><br><span style="font-size:13px;margin-top:4px;display:block">${fullSentence}</span>`;
  }
  fb.style.display = 'block';
  document.getElementById('nav-row').style.display = 'flex';
  document.getElementById('q-score-mini').textContent = `맞힌 수: ${correct}`;
}

function skipQ() {
  if (answered) return;
  const q = questions[idx];
  skipped++;
  wrongList.push(q);
  answered = true;
  document.getElementById('ans-input').disabled = true;
  const fb = document.getElementById('feedback');
  fb.className = 'feedback skip';
  const fullSentence = q.s.replace(/\[([^\]]+)\]/g, '<strong>$1</strong>');
  fb.innerHTML = `건너뜀. 정답: <strong>${q.a}</strong><br><span style="font-size:13px;margin-top:4px;display:block">${fullSentence}</span>`;
  fb.style.display = 'block';
  document.getElementById('nav-row').style.display = 'flex';
}

function revealAll() {
  const q = questions[idx];
  const fb = document.getElementById('feedback');
  fb.className = 'feedback skip';
  const fullSentence = q.s.replace(/\[([^\]]+)\]/g, '<strong>$1</strong>');
  fb.innerHTML = `정답: <strong>${q.a}</strong><br><span style="font-size:13px;margin-top:4px;display:block">${fullSentence}</span>`;
  fb.style.display = 'block';
}

function nextQ() {
  idx++;
  if (idx >= questions.length) { showResult(); return; }
  renderQ();
}

/* ===== 결과 화면 ===== */
function showResult() {
  document.getElementById('q-card').style.display = 'none';
  const total = questions.length;
  const pct   = Math.round((correct / total) * 100);
  document.getElementById('r-correct').textContent = correct;
  document.getElementById('r-wrong').textContent   = wrong;
  document.getElementById('r-skip').textContent    = skipped;
  document.getElementById('r-pct').textContent     = pct + '%';
  document.getElementById('result-section').style.display = '';

  if (wrongList.length > 0 && !isRetry) {
    const rl = document.getElementById('retry-list');
    rl.innerHTML = wrongList.map(q => {
      const label = q.s.replace(/\[([^\]]+)\]/g, '___');
      return `<div style="font-size:13px;padding:6px 0;border-bottom:1px solid #eee">
                <span class="tag wrong-tag">오답</span>${label}
              </div>`;
    }).join('');
    document.getElementById('retry-section').style.display = '';
  }
}

/* ===== 심화 주관식 ===== */
function renderEssay() {
  const el = document.getElementById('essay-list');
  el.innerHTML = ESSAYS.map((e, i) => `
    <div class="essay-q"><span class="essay-num">Q${i + 1}.</span>${e.q}</div>
    <div style="margin-bottom:0.5rem">
      <button class="btn" onclick="toggleRef(${i})">모범 답안 보기 / 숨기기</button>
    </div>
    <div class="ref-box" id="ref-${i}"><pre>${e.a}</pre></div>
    <div style="margin-bottom:1rem"></div>
  `).join('');
}

function toggleRef(i) {
  document.getElementById('ref-' + i).classList.toggle('show');
}

/* ===== 초기 실행 ===== */
startQuiz();
</script>
</body>
</html>
