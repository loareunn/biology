let currentSet = [];
let idx = 0;

function loadChapter(n) {
    document.querySelectorAll('.chapter-select button').forEach(b => b.classList.remove('active'));
    document.getElementById('btn'+n).classList.add('active');
    currentSet = rawData[n].map(s => {
        const answers = [];
        const question = s.replace(/{([^}]+)}/g, (m, p1) => {
            answers.push(p1);
            return `<input type="text" data-ans="${p1}" onfocus="showHint('${p1.length}')">`;
        });
        return { question, answers };
    }).sort(() => Math.random() - 0.5);
    idx = 0;
    document.getElementById('quiz-area').style.display = 'block';
    render();
}

function render() {
    if(idx >= currentSet.length) {
        document.getElementById('content').innerHTML = "<h2>축하합니다! 해당 단원을 모두 완료했습니다.</h2>";
        return;
    }
    const q = currentSet[idx];
    document.getElementById('content').innerHTML = `<div class="sentence">${q.question}</div>`;
    document.getElementById('hint-area').innerText = "";
    document.getElementById('status').innerText = `문항: ${idx + 1} / ${currentSet.length}`;
}

function showHint(len) {
    document.getElementById('hint-area').innerText = `현재 빈칸 힌트: ${len}글자`;
}

function checkAnswers() {
    const inputs = document.querySelectorAll('#content input');
    let allCorrect = true;
    inputs.forEach(i => {
        if(i.value.trim() === i.dataset.ans) i.className = 'correct';
        else { i.className = 'wrong'; allCorrect = false; }
    });
}

function showAnswer() {
    document.querySelectorAll('#content input').forEach(i => {
        i.value = i.dataset.ans;
        i.className = 'correct';
    });
}

function nextQuestion() {
    idx = (idx + 1) % currentSet.length;
    render();
}
</script>
</body>
</html>
